# In packed mode (`pnpm tk dev play:packed`), this playground installs with
# `--ignore-workspace` against `.tarballs/`. That bypasses the root workspace's
# `pnpm.onlyBuiltDependencies` allowlist, so pnpm 11 hard-fails the pre-`dev`
# install check with ERR_PNPM_IGNORED_BUILDS on esbuild / @parcel/watcher /
# vue-demi. We don't ship `node_modules` from here — it's only used to
# typecheck + dev-serve against the built tarballs — so silently skipping the
# native postinstall scripts is fine.
strict-dep-builds=false

# Don't auto-run `pnpm install` before every script invocation. The use-packed.ts
# script has already done the install with the right flags; re-running it on
# every `nuxt dev` invocation bypasses our local config and re-fails.
verify-deps-before-run=false
