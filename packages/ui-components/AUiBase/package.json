{
  "name": "@alikhalilll/a-ui-base",
  "version": "1.0.0",
  "private": true,
  "description": "Internal workspace foundation for the @alikhalilll/a-* component packages. NOT published — its JS, types, and tokens are bundled into each component's dist by tsdown.",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./tokens.css": "./tokens.css",
    "./theme.css": "./theme.css"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsdown",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "rimraf": "^6.0.1",
    "tsdown": "0.22.0",
    "typescript": "^5.9.2"
  }
}
