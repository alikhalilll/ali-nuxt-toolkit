{
  "name": "@alikhalilll/nuxt-api-provider",
  "version": "1.3.0",
  "description": "Strongly-typed fetch client for Nuxt 3/4 with interceptors, retry/backoff, and a framework-agnostic core.",
  "license": "MIT",
  "author": "alikhalilll",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alikhalilll/ali-nuxt-toolkit.git",
    "directory": "packages/api-provider"
  },
  "homepage": "https://alikhalilll.github.io/ali-nuxt-toolkit/api-provider",
  "bugs": {
    "url": "https://github.com/alikhalilll/ali-nuxt-toolkit/issues"
  },
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "nuxt",
    "nuxt-module",
    "fetch",
    "http-client",
    "api",
    "interceptors",
    "retry"
  ],
  "exports": {
    ".": {
      "types": "./dist/module.d.ts",
      "import": "./dist/module.mjs"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.mjs"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/module.d.ts",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/module.d.ts"
      ],
      "core": [
        "./dist/core/index.d.ts"
      ],
      "types": [
        "./dist/types/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsdown",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "validate-dist": "tsx ../../scripts/validate/dist-validate.ts --pkg api-provider",
    "validate-consumer": "tsx ../../scripts/validate/consumer-validate.ts --pkg api-provider",
    "validate": "pnpm build && pnpm validate-dist && pnpm validate-consumer",
    "prepack": "pnpm build",
    "prepublishOnly": "pnpm validate"
  },
  "peerDependencies": {
    "@nuxt/kit": "^3.0.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "@nuxt/kit": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nuxt/kit": "^4.0.0",
    "@nuxt/schema": "^4.0.0",
    "@types/node": "^22.13.0",
    "rimraf": "^6.0.1",
    "tsdown": "0.22.0",
    "typescript": "^5.9.2",
    "unrun": "0.3.0"
  }
}
