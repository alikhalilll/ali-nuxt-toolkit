{
  "name": "@alikhalilll/nuxt-crypto",
  "version": "1.3.0",
  "description": "Symmetric Web Crypto service for Nuxt 3/4. AES-256-GCM + PBKDF2 with key caching, pluggable algorithms, and optional device-fingerprint binding.",
  "license": "MIT",
  "author": "alikhalilll",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alikhalilll/ali-nuxt-toolkit.git",
    "directory": "packages/crypto"
  },
  "homepage": "https://alikhalilll.github.io/ali-nuxt-toolkit/crypto",
  "bugs": {
    "url": "https://github.com/alikhalilll/ali-nuxt-toolkit/issues"
  },
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "nuxt",
    "nuxt-module",
    "crypto",
    "encryption",
    "aes-gcm",
    "web-crypto",
    "pbkdf2",
    "fingerprint"
  ],
  "exports": {
    ".": {
      "types": "./dist/module.d.ts",
      "import": "./dist/module.mjs"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.mjs"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.mjs"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/module.d.ts",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/module.d.ts"
      ],
      "core": [
        "./dist/core/index.d.ts"
      ],
      "server": [
        "./dist/server/index.d.ts"
      ],
      "types": [
        "./dist/types/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsdown",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "validate-dist": "tsx ../../scripts/validate/dist-validate.ts --pkg crypto",
    "validate-consumer": "tsx ../../scripts/validate/consumer-validate.ts --pkg crypto",
    "validate": "pnpm build && pnpm validate-dist && pnpm validate-consumer",
    "prepack": "pnpm build",
    "prepublishOnly": "pnpm validate"
  },
  "peerDependencies": {
    "@nuxt/kit": "^3.0.0 || ^4.0.0",
    "h3": "^1.0.0 || ^2.0.0"
  },
  "peerDependenciesMeta": {
    "@nuxt/kit": {
      "optional": true
    },
    "h3": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nuxt/kit": "^4.0.0",
    "@nuxt/schema": "^4.0.0",
    "@types/node": "^22.13.0",
    "h3": "^1.13.0",
    "rimraf": "^6.0.1",
    "tsdown": "0.22.0",
    "typescript": "^5.9.2",
    "unrun": "0.3.0"
  }
}
