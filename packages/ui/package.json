{
  "name": "@alikhalilll/ui",
  "version": "2.0.0",
  "description": "Headless, shadcn-vue style Vue 3 component library — every component is its own importable subpath (`@alikhalilll/ui/tell-input`, `@alikhalilll/ui/popover`, …) so users pay only for what they actually use.",
  "license": "MIT",
  "author": "alikhalilll",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alikhalilll/ali-nuxt-toolkit.git",
    "directory": "packages/ui"
  },
  "homepage": "https://alikhalilll.github.io/ali-nuxt-toolkit/ui",
  "bugs": {
    "url": "https://github.com/alikhalilll/ali-nuxt-toolkit/issues"
  },
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "vue",
    "vue3",
    "nuxt",
    "components",
    "ui",
    "headless",
    "shadcn",
    "tel-input",
    "phone-input",
    "reka-ui",
    "vaul-vue"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./tell-input": {
      "import": {
        "types": "./dist/tell-input/index.d.ts",
        "default": "./dist/tell-input/index.js"
      },
      "require": {
        "types": "./dist/tell-input/index.d.cts",
        "default": "./dist/tell-input/index.cjs"
      }
    },
    "./input": {
      "import": {
        "types": "./dist/input/index.d.ts",
        "default": "./dist/input/index.js"
      },
      "require": {
        "types": "./dist/input/index.d.cts",
        "default": "./dist/input/index.cjs"
      }
    },
    "./popover": {
      "import": {
        "types": "./dist/popover/index.d.ts",
        "default": "./dist/popover/index.js"
      },
      "require": {
        "types": "./dist/popover/index.d.cts",
        "default": "./dist/popover/index.cjs"
      }
    },
    "./drawer": {
      "import": {
        "types": "./dist/drawer/index.d.ts",
        "default": "./dist/drawer/index.js"
      },
      "require": {
        "types": "./dist/drawer/index.d.cts",
        "default": "./dist/drawer/index.cjs"
      }
    },
    "./responsive-popover": {
      "import": {
        "types": "./dist/responsive-popover/index.d.ts",
        "default": "./dist/responsive-popover/index.js"
      },
      "require": {
        "types": "./dist/responsive-popover/index.d.cts",
        "default": "./dist/responsive-popover/index.cjs"
      }
    },
    "./utils": {
      "import": {
        "types": "./dist/utils/index.d.ts",
        "default": "./dist/utils/index.js"
      },
      "require": {
        "types": "./dist/utils/index.d.cts",
        "default": "./dist/utils/index.cjs"
      }
    },
    "./nuxt": {
      "import": {
        "types": "./dist/nuxt/index.d.ts",
        "default": "./dist/nuxt/index.js"
      },
      "require": {
        "types": "./dist/nuxt/index.d.cts",
        "default": "./dist/nuxt/index.cjs"
      }
    },
    "./resolver": {
      "import": {
        "types": "./dist/resolver/index.d.ts",
        "default": "./dist/resolver/index.js"
      },
      "require": {
        "types": "./dist/resolver/index.d.cts",
        "default": "./dist/resolver/index.cjs"
      }
    },
    "./assets/styles.css": "./dist/assets/styles.css",
    "./styles.css": "./dist/assets/styles.css",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "entries/**/*.vue",
    "entries/**/*.ts",
    "utils/**/*.ts",
    "entries/**/README.md",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build:css": "tailwindcss -i assets/styles.src.css -o dist/assets/styles.css --minify",
    "build:bundle": "tsdown",
    "build:dts": "vue-tsc -p tsconfig.dist.json",
    "build:copy-sources": "tsx scripts/build/copy-sources.ts",
    "build:fix-dts": "tsx scripts/build/fix-dts-imports.ts",
    "build:entry-dts": "tsx scripts/build/generate-entry-dts.ts",
    "build:strip": "tsx scripts/build/strip-vls-wrapper.ts",
    "build:merge-css": "tsx scripts/build/merge-sfc-styles.ts",
    "build:verify": "tsx scripts/build/verify-exports.ts",
    "build": "pnpm clean && pnpm build:bundle && pnpm build:dts && pnpm build:copy-sources && pnpm build:fix-dts && pnpm build:entry-dts && pnpm build:strip && pnpm build:css && pnpm build:merge-css && pnpm build:verify",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "validate-dist": "tsx ../../scripts/validate/dist-validate.ts --pkg ui",
    "validate-consumer": "tsx ../../scripts/validate/consumer-validate.ts --pkg ui",
    "validate": "pnpm build && pnpm validate-dist && pnpm validate-consumer",
    "prepack": "pnpm build",
    "prepublishOnly": "pnpm validate"
  },
  "peerDependencies": {
    "@nuxt/kit": "^3.0.0 || ^4.0.0",
    "unplugin-vue-components": "^28.0.0 || ^29.0.0 || ^30.0.0 || ^31.0.0 || ^32.0.0",
    "vue": "^3.5.0"
  },
  "peerDependenciesMeta": {
    "@nuxt/kit": {
      "optional": true
    },
    "unplugin-vue-components": {
      "optional": true
    }
  },
  "dependencies": {
    "@vueuse/core": "^14.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "libphonenumber-js": "^1.12.0",
    "reka-ui": "^2.9.0",
    "tailwind-merge": "^2.6.0",
    "vaul-vue": "^0.4.0"
  },
  "devDependencies": {
    "@ampproject/remapping": "^2.3.0",
    "@nuxt/kit": "^4.4.2",
    "@nuxt/schema": "^4.4.2",
    "@tailwindcss/cli": "^4.0.0",
    "@tsdown/css": "0.22.0",
    "@types/node": "^22.13.0",
    "magic-string": "^0.30.21",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.0.0",
    "tsdown": "0.22.0",
    "typescript": "^5.9.2",
    "unplugin-vue": "7.2.0",
    "unplugin-vue-components": "^32.1.0",
    "unrun": "0.3.0",
    "vue": "^3.5.0",
    "vue-tsc": "^3.2.4"
  }
}
