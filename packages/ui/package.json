{
  "name": "@alikhalilll/ui",
  "version": "1.2.4",
  "description": "Headless, shadcn-vue style Vue 3 component library — every component is its own importable subpath (`@alikhalilll/ui/tell-input`, `@alikhalilll/ui/popover`, …) so users pay only for what they actually use.",
  "license": "MIT",
  "author": "alikhalilll",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alikhalilll/ali-nuxt-toolkit.git",
    "directory": "packages/ui"
  },
  "homepage": "https://alikhalilll.github.io/ali-nuxt-toolkit/ui",
  "bugs": {
    "url": "https://github.com/alikhalilll/ali-nuxt-toolkit/issues"
  },
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "vue",
    "vue3",
    "nuxt",
    "components",
    "ui",
    "headless",
    "shadcn",
    "tel-input",
    "phone-input",
    "reka-ui",
    "vaul-vue"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tell-input": {
      "types": "./dist/tell-input.d.ts",
      "import": "./dist/tell-input.js",
      "require": "./dist/tell-input.cjs"
    },
    "./input": {
      "types": "./dist/input.d.ts",
      "import": "./dist/input.js",
      "require": "./dist/input.cjs"
    },
    "./popover": {
      "types": "./dist/popover.d.ts",
      "import": "./dist/popover.js",
      "require": "./dist/popover.cjs"
    },
    "./drawer": {
      "types": "./dist/drawer.d.ts",
      "import": "./dist/drawer.js",
      "require": "./dist/drawer.cjs"
    },
    "./responsive-popover": {
      "types": "./dist/responsive-popover.d.ts",
      "import": "./dist/responsive-popover.js",
      "require": "./dist/responsive-popover.cjs"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/utils.js",
      "require": "./dist/utils.cjs"
    },
    "./nuxt": {
      "types": "./dist/nuxt.d.ts",
      "import": "./dist/nuxt.js",
      "require": "./dist/nuxt.cjs"
    },
    "./resolver": {
      "types": "./dist/resolver.d.ts",
      "import": "./dist/resolver.js",
      "require": "./dist/resolver.cjs"
    },
    "./assets/styles.css": "./dist/assets/styles.css",
    "./styles.css": "./dist/assets/styles.css",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "entries/**/*.vue",
    "entries/**/*.ts",
    "utils/**/*.ts",
    "entries/**/README.md",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build:css": "tailwindcss -i assets/styles.src.css -o dist/assets/styles.css --minify",
    "build:bundle": "tsdown",
    "build:strip": "node scripts/build/strip-vls-wrapper.mjs",
    "build:verify": "node scripts/build/verify-exports.mjs",
    "build": "pnpm clean && pnpm build:bundle && pnpm build:strip && pnpm build:css && pnpm build:verify",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "prepack": "pnpm build"
  },
  "peerDependencies": {
    "@nuxt/kit": "^3.0.0 || ^4.0.0",
    "unplugin-vue-components": "^28.0.0 || ^29.0.0 || ^30.0.0 || ^31.0.0 || ^32.0.0",
    "vue": "^3.5.0"
  },
  "peerDependenciesMeta": {
    "@nuxt/kit": {
      "optional": true
    },
    "unplugin-vue-components": {
      "optional": true
    }
  },
  "dependencies": {
    "@vueuse/core": "^14.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "libphonenumber-js": "^1.12.0",
    "lucide-vue-next": "^0.460.0",
    "reka-ui": "^2.9.0",
    "tailwind-merge": "^2.6.0",
    "vaul-vue": "^0.4.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@nuxt/kit": "^4.4.2",
    "@tailwindcss/cli": "^4.0.0",
    "@types/node": "^22.13.0",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.0.0",
    "tsdown": "0.22.0",
    "typescript": "^5.9.2",
    "unplugin-vue": "7.2.0",
    "unplugin-vue-components": "^32.1.0",
    "vue": "^3.5.0",
    "vue-tsc": "^3.2.4"
  }
}
