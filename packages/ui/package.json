{
  "name": "@alikhalilll/ui",
  "version": "1.2.0",
  "description": "Headless, shadcn-vue style Vue 3 component library — every component is its own importable subpath (`@alikhalilll/ui/tell-input`, `@alikhalilll/ui/popover`, …) so users pay only for what they actually use.",
  "license": "MIT",
  "author": "alikhalilll",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alikhalilll/ali-nuxt-toolkit.git",
    "directory": "packages/ui"
  },
  "homepage": "https://alikhalilll.github.io/ali-nuxt-toolkit/ui",
  "bugs": {
    "url": "https://github.com/alikhalilll/ali-nuxt-toolkit/issues"
  },
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "vue",
    "vue3",
    "nuxt",
    "components",
    "ui",
    "headless",
    "shadcn",
    "tel-input",
    "phone-input",
    "reka-ui",
    "vaul-vue"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./tell-input": {
      "types": "./dist/tell-input.d.ts",
      "import": "./dist/tell-input.mjs"
    },
    "./input": {
      "types": "./dist/input.d.ts",
      "import": "./dist/input.mjs"
    },
    "./popover": {
      "types": "./dist/popover.d.ts",
      "import": "./dist/popover.mjs"
    },
    "./drawer": {
      "types": "./dist/drawer.d.ts",
      "import": "./dist/drawer.mjs"
    },
    "./responsive-popover": {
      "types": "./dist/responsive-popover.d.ts",
      "import": "./dist/responsive-popover.mjs"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/utils.mjs"
    },
    "./assets/styles.css": "./dist/assets/styles.css",
    "./styles.css": "./dist/assets/styles.css",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "entries/**/README.md",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "pnpm clean && vite build && node -e \"const fs=require('node:fs'); fs.mkdirSync('dist/assets',{recursive:true}); fs.copyFileSync('assets/styles.css','dist/assets/styles.css');\"",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "prepack": "pnpm build"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "dependencies": {
    "@vueuse/core": "^14.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "libphonenumber-js": "^1.12.0",
    "lucide-vue-next": "^0.460.0",
    "reka-ui": "^2.9.0",
    "tailwind-merge": "^2.6.0",
    "vaul-vue": "^0.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.2",
    "vite": "^6.4.2",
    "vite-plugin-dts": "^4.5.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.2.0"
  }
}
