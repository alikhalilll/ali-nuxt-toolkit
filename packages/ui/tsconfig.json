{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["node"],
    "jsx": "preserve",
    "verbatimModuleSyntax": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "index.ts",
    "entries/**/index.ts",
    "entries/**/components/*.vue",
    "entries/**/components/*.ts",
    "entries/**/composables/*.ts",
    "entries/**/utils/*.ts",
    "utils/**/*.ts",
    "vite.config.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
