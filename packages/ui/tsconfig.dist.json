{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": true,
    "rootDir": ".",
    "outDir": "dist/runtime",
    "noImplicitAny": false,
    "strict": false,
    "noEmitOnError": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": [
    "index.ts",
    "entries/**/*.ts",
    "entries/**/*.vue",
    "utils/**/*.ts",
    "nuxt/**/*.ts",
    "resolver/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "scripts"]
}
