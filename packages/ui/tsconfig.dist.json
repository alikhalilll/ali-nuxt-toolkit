{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationMap": true,
    "noEmitOnError": false,
    "rootDir": ".",
    "outDir": "./dist"
  },
  "include": [
    "index.ts",
    "entries/**/index.ts",
    "entries/**/components/*.vue",
    "entries/**/components/*.ts",
    "entries/**/composables/*.ts",
    "entries/**/utils/*.ts",
    "utils/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "vite.config.ts", "**/*.test.ts", "**/*.spec.ts"]
}
