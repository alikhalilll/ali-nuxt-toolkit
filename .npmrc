# Scope registry — pin scoped packages to the public npm registry.
@alikhalilll:registry=https://registry.npmjs.org/

# Auth via env var. Set NPM_TOKEN in CI (GitHub Actions secret) or in your
# shell for local publishes. Never commit a real token here.
//registry.npmjs.org/:_authToken=${NPM_TOKEN}

# Publish scoped packages as public by default.
access=public
