{
  "name": "ali-nuxt-toolkit",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" --filter \"./packages/ui-components/*\" build",
    "typecheck": "pnpm -r --filter \"./packages/*\" --filter \"./packages/ui-components/*\" typecheck",
    "clean": "pnpm -r --filter \"./packages/*\" --filter \"./packages/ui-components/*\" clean",
    "tk": "tsx scripts/tk.ts",
    "play": "pnpm -C playgrounds/nuxt dev",
    "play:packed": "tsx scripts/playground/use-packed.ts --use-packed",
    "play:packed:restore": "tsx scripts/playground/use-packed.ts --restore",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "commitlint": "commitlint",
    "prepare": "husky",
    "pack:all": "tsx scripts/pack/pack-all.ts --all",
    "pack:api-provider": "tsx scripts/pack/pack-all.ts --pkg api-provider",
    "pack:crypto": "tsx scripts/pack/pack-all.ts --pkg crypto",
    "pack:auto-middleware": "tsx scripts/pack/pack-all.ts --pkg auto-middleware",
    "pack:ui-components": "tsx scripts/pack/pack-all.ts --pkg a-ui-base,a-input,a-popover,a-drawer,a-responsive-popover,a-tel-input",
    "validate": "pnpm build && pnpm -r --filter \"./packages/*\" --filter \"./packages/ui-components/*\" run validate-dist && tsx scripts/validate/consumer-validate.ts --all",
    "validate:api-provider": "pnpm -C packages/api-provider validate",
    "validate:crypto": "pnpm -C packages/crypto validate",
    "validate:auto-middleware": "pnpm -C packages/auto-middleware validate",
    "validate:consumer": "tsx scripts/validate/consumer-validate.ts --all",
    "release": "tsx scripts/release/index.ts --interactive",
    "release:all": "tsx scripts/release/index.ts --all --interactive",
    "release:api-provider": "tsx scripts/release/index.ts --pkg api-provider --interactive",
    "release:crypto": "tsx scripts/release/index.ts --pkg crypto --interactive",
    "release:auto-middleware": "tsx scripts/release/index.ts --pkg auto-middleware --interactive",
    "release:dry": "tsx scripts/release/index.ts --interactive --dry-run",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "pnpm build && changeset publish",
    "changeset:status": "changeset status --verbose"
  },
  "devDependencies": {
    "@ampproject/remapping": "^2.3.0",
    "@arethetypeswrong/cli": "0.18.2",
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.0",
    "@commitlint/cli": "^20.0.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/js": "^9.0.0",
    "@inquirer/prompts": "^8.3.2",
    "@types/minimist": "^1.2.5",
    "@types/node": "^22.13.0",
    "magic-string": "^0.30.21",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-vue": "^10.0.0",
    "execa": "^9.6.1",
    "globals": "^17.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.5.0",
    "minimist": "^1.2.8",
    "picocolors": "^1.1.1",
    "prettier": "^3.5.0",
    "publint": "^0.3.21",
    "tsx": "^4.20.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.30.0",
    "vue-eslint-parser": "^10.0.0"
  },
  "lint-staged": {
    "*.{js,ts,vue,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss,md,json}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "@parcel/watcher"
    ]
  }
}
