{
  "name": "ali-nuxt-toolkit",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build",
    "typecheck": "pnpm -r --filter \"./packages/*\" typecheck",
    "clean": "pnpm -r --filter \"./packages/*\" clean",
    "play": "pnpm -C playgrounds/nuxt dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "commitlint": "commitlint",
    "prepare": "husky",
    "pack:all": "node scripts/pack-all.mjs --all",
    "pack:api-provider": "node scripts/pack-all.mjs --pkg api-provider",
    "pack:crypto": "node scripts/pack-all.mjs --pkg crypto",
    "pack:auto-middleware": "node scripts/pack-all.mjs --pkg auto-middleware",
    "release": "node scripts/release/index.mjs --interactive",
    "release:all": "node scripts/release/index.mjs --all --interactive",
    "release:api-provider": "node scripts/release/index.mjs --pkg api-provider --interactive",
    "release:crypto": "node scripts/release/index.mjs --pkg crypto --interactive",
    "release:auto-middleware": "node scripts/release/index.mjs --pkg auto-middleware --interactive",
    "release:dry": "node scripts/release/index.mjs --interactive --dry-run",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "pnpm build && changeset publish",
    "changeset:status": "changeset status --verbose"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.0",
    "@commitlint/cli": "^20.0.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/js": "^9.0.0",
    "@inquirer/prompts": "^8.3.2",
    "@types/node": "^22.13.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-vue": "^10.0.0",
    "globals": "^17.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.5.0",
    "minimist": "^1.2.8",
    "picocolors": "^1.1.1",
    "prettier": "^3.5.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.30.0",
    "vue-eslint-parser": "^10.0.0"
  },
  "lint-staged": {
    "*.{js,ts,vue,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss,md,json}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "@parcel/watcher"
    ]
  }
}
