{
  "name": "ali-nuxt-toolkit",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "tk": "tsx scripts/tk.ts",
    "build": "tsx scripts/tk.ts build all",
    "typecheck": "tsx scripts/tk.ts typecheck all",
    "clean": "tsx scripts/tk.ts clean all",
    "play": "tsx scripts/tk.ts dev play",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "commitlint": "commitlint",
    "prepare": "husky",
    "changeset": "changeset"
  },
  "devDependencies": {
    "@ampproject/remapping": "^2.3.0",
    "@arethetypeswrong/cli": "0.18.2",
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.0",
    "@commitlint/cli": "^20.0.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/js": "^9.0.0",
    "@inquirer/prompts": "^8.3.2",
    "@types/minimist": "^1.2.5",
    "@types/node": "^22.13.0",
    "magic-string": "^0.30.21",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-vue": "^10.0.0",
    "execa": "^9.6.1",
    "globals": "^17.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.5.0",
    "minimist": "^1.2.8",
    "picocolors": "^1.1.1",
    "prettier": "^3.5.0",
    "publint": "^0.3.21",
    "tsx": "^4.20.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.30.0",
    "vue-eslint-parser": "^10.0.0"
  },
  "lint-staged": {
    "*.{js,ts,vue,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss,md,json}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "@parcel/watcher"
    ]
  }
}
